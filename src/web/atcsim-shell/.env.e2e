# E2E-only Vite env (loaded via `vite --mode e2e`). Committed intentionally
# (`git add -f`, the repo .gitignore excludes .env*). Values are dummy: the
# Playwright E2E run stubs the Maps token and all atlas.microsoft.com traffic,
# so no real Azure Maps subscription is needed. Same-origin API base — the test
# intercepts /api/aircraft and /api/maps/token.
VITE_MAPS_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_FLIGHT_API_BASE_URL=
