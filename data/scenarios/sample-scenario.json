  "script": [
    {
      "stepId": "STEP-01",
      "goldenId": "G-01",
      "order": 1,
      "type": "atc_instruction",
      "targetCallsign": "SWR456",
      "expectedAtcTransmission": "Swiss 456, turn right heading 290 degrees, and climb flight level 370.",
      "expectedCommands": [
        { "type": "SELECT_AIRCRAFT", "callsign": "SWR456" },
        { "type": "SET_HEADING", "direction": "RIGHT", "degrees": 290 },
        { "type": "SET_FLIGHT_LEVEL", "value": 370 }
      ],
      "expectedReadBack": "Turning right heading 290 degrees and climbing to flight level 370, Swiss 456.",
      "phraseologyPoints": ["callsign echo", "heading with turn direction", "level change (flight level)"],
      "exercises": "Standard vector + climb; callsign read-back discipline."
    },
    {
      "stepId": "STEP-02",
      "goldenId": "G-02",
      "order": 2,
      "type": "atc_instruction",
      "targetCallsign": "N123AB",
      "expectedAtcTransmission": "N123AB, crossing to Schrattenfluh approved, descend 5'000 feet, QNH 1019, report crossing completed.",
      "expectedCommands": [
        { "type": "SELECT_AIRCRAFT", "callsign": "N123AB" },
        { "type": "SET_ALTITUDE", "feet": 5000 },
        { "type": "SET_QNH", "value": 1019 },
        { "type": "REPORT_POINT", "reportName": "CROSSING_COMPLETED" }
      ],
      "expectedReadBack": "Crossing to Schrattenfluh approved and descending to 5,000 feet, QNH 1019, call you completed N123AB.",
      "phraseologyPoints": ["Swiss toponym (Schrattenfluh)", "altitude in feet with QNH", "conditional report read-back"],
      "exercises": "Toponym recognition; QNH; conditional report."
    },
    {
      "stepId": "STEP-03",
      "goldenId": "G-03",
      "order": 3,
      "type": "atc_instruction",
      "targetCallsign": "HELINA",
      "expectedAtcTransmission": "Heli-NA, Report HE, QNH 1023, look out for opposite helicopter just departed FATO climbing direction Evolène.",
      "expectedCommands": [
        { "type": "SELECT_AIRCRAFT", "callsign": "HELINA" },
        { "type": "SET_QNH", "value": 1023 },
        { "type": "REPORT_POINT", "reportName": "HE" },
        { "type": "TRAFFIC_INFO", "description": "opposite helicopter departing FATO climbing towards Evolène", "movement": "climbing", "reference": "Evolène" }
      ],
      "expectedReadBack": "Call you HE, QNH 1023, looking out for traffic Heli-NA.",
      "phraseologyPoints": ["helicopter R/T", "reporting point HE", "Swiss municipality (Evolène)", "traffic look-out"],
      "exercises": "Helicopter phraseology; FATO; municipality name; partial read-back of traffic."
    },
    {
      "stepId": "STEP-04",
      "goldenId": "G-04",
      "order": 4,
      "type": "atc_instruction",
      "targetCallsign": "NJE396J",
      "expectedAtcTransmission": "NJE396J, opposite traffic 11 o'clock position 6 miles 4'900 feet climbing eastbound, maintain south of the IGS axis.",
      "expectedCommands": [
        { "type": "SELECT_AIRCRAFT", "callsign": "NJE396J" },
        { "type": "TRAFFIC_INFO", "clockPosition": 11, "distanceNm": 6, "altitudeFt": 4900, "movement": "climbing eastbound" },
        { "type": "REPORT_POINT", "reportName": "MAINTAIN_SOUTH_OF_IGS_AXIS" }
      ],
      "expectedReadBack": "Looking out NJE396J.",
      "phraseologyPoints": ["traffic advisory (clock/distance/level/movement)", "spatial constraint (IGS axis)", "minimal correct read-back"],
      "exercises": "Traffic advisory; acceptable partial read-back."
    }
